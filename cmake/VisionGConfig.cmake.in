# Generated VisionG package config / 自动生成的 VisionG 包配置
get_filename_component(VISIONG_PACKAGE_PREFIX "${CMAKE_CURRENT_LIST_DIR}/.." ABSOLUTE)

set(VISIONG_VERSION_STRING "@VISIONG_VERSION@")
set(VISIONG_PACKAGE_WITH_IVE @VISIONG_ENABLE_IVE@)
set(VISIONG_PACKAGE_WITH_NPU @VISIONG_ENABLE_NPU@)
set(VISIONG_PACKAGE_WITH_GUI @VISIONG_ENABLE_GUI@)
set(VISIONG_PACKAGE_COMPONENTS "")
if(VISIONG_PACKAGE_WITH_IVE)
    list(APPEND VISIONG_PACKAGE_COMPONENTS IVE)
endif()
if(VISIONG_PACKAGE_WITH_NPU)
    list(APPEND VISIONG_PACKAGE_COMPONENTS NPU)
endif()
if(VISIONG_PACKAGE_WITH_GUI)
    list(APPEND VISIONG_PACKAGE_COMPONENTS GUI)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/VisionGTargets.cmake")
